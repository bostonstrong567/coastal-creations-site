{
  "name": "mary-jean-s-costal-creations",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:create": "wrangler d1 create coastal-creations-db",
    "db:migrate": "wrangler d1 migrations apply coastal-creations-db --remote"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wrangler": "^4.95.0"
  }
}
